.env
PORT=5000
JWT_SECRET=your-super-secret-key-change-this-in-production-12345
NODE_ENV=development

# Required in production if you want accounts/projects to survive Render restarts.
# Create a Render Postgres database and set DATABASE_URL to its Internal Database URL.
DATABASE_URL=postgres://user:password@host:5432/database
DATABASE_SSL=true

# Optional email settings for password reset links
# If not provided, reset URLs will be printed in the server logs.
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-smtp-user@example.com
EMAIL_PASS=your-smtp-password
EMAIL_FROM=your-sender@example.com

# Optional frontend URL used by password reset emails in deployed environments
FRONTEND_URL=https://your-deployed-domain.example.com

# Optional admin login report settings
# Use this token in the x-admin-token header or Authorization: Bearer header.
ADMIN_TOKEN=your-private-admin-report-token
ADMIN_REPORT_EMAIL=nikunj.verma@live.com
