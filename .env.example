.env
PORT=5000
JWT_SECRET=your-super-secret-key-change-this-in-production-12345
NODE_ENV=development

# Optional email settings for password reset links
# If not provided, reset URLs will be printed in the server logs.
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-smtp-user@example.com
EMAIL_PASS=your-smtp-password
EMAIL_FROM=your-sender@example.com

# Optional frontend URL used by password reset emails in deployed environments
FRONTEND_URL=https://your-deployed-domain.example.com
